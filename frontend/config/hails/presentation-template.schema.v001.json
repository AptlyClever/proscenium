{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "presentation-template.schema.v001.json",
  "title": "Hail presentation template",
  "type": "object",
  "required": ["template_id", "label"],
  "properties": {
    "template_id": { "type": "string", "minLength": 1 },
    "label": { "type": "string" },
    "stage_assets": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "glyph_motion": {
      "type": "object",
      "properties": {
        "profile": { "type": "string" },
        "resolve_style": { "type": "string" }
      }
    },
    "choreography_anchors": { "type": "object" },
    "presentation_overlay": { "type": "object" }
  },
  "additionalProperties": false
}
