# Hail platform E2E — homelab environment contract
# Copy to hail-platform.e2e.env and adjust. See docs/hails/NAMING.md

# Lane: fast | platform | device
HAIL_PLATFORM_E2E_LANE=platform

AXIOM_BASE_URL=http://192.168.68.93:7895
LCARD_SERVICE_URL=http://127.0.0.1:8787
ARCADE_OVERLAY_URL=http://192.168.68.105:8765
ADB_TARGET=192.168.68.105:5555

# Known catalog_ready hail for acceptance/happy-send (optional)
# HAIL_PLATFORM_HAPPY_SEND_HAIL_ID=

# Skip LCARD smokes in fast lane (set 1 for PR-style runs)
SKIP_LCARD_COLLECTIVE_VERIFY=0

# Skip live Forge/Hails UI capture in parity verifiers
LIVE_PREVIEW_SKIP=1

# Reuse existing frontend build in capture scripts
PACKAGE_PARITY_SKIP_BUILD=1
PACKAGE_PARITY_V2_SKIP_BUILD=1
