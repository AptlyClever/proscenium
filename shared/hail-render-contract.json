      "horizontalFraction": 0.065,
      "topFraction": 0.085,
      "bottomFraction": 0.105,
      "upperCenterExtraTopFraction": 0.035,
      "centerSoftVerticalFraction": 0.07
    },
    "layoutFractions": {
      "groupWidth": 0.24,
      "groupHeight": 0.26
    }
  },
  "glyphs": {
