{
  "version": "v001-animation-impact",
  "description": "Shared Control Alt Hails render payload and layout constants. Preview harness reads this file; Android mirrors after preview acceptance. Scale/color/animation grammar is preview-only until Axiom owns the visual contract.",
  "payloadFields": [
    "hail_id",
    "effect_id",
    "glyph_id",
    "palette_id",
    "message",
    "duration_ms",
    "placement_id",
    "placement_mode",
    "x_percent",
    "y_percent"
  ],
  "message": {
    "maxLength": 120,
    "plainTextOnly": true
  },
  "placement": {
    "modePreset": "preset",
    "modeCustom": "custom",
    "minPercent": 5,
    "maxPercent": 95,
