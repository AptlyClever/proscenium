        "particle_travel_scale": "Transport particle drift/travel (enter/exit only)",
        "glow_radius_scale": "Transport glow reach during materialization; modest stable glyph glow via renderer",
        "anchor_weight": "Arrival anchor glyph visual weight",
        "message_backing_emphasis": "Message backing pad prominence"
      }
    },
