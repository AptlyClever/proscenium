{
  "version": "v001-team-pass-visual-language",
  "description": "Shared Control Alt Hails render payload and layout constants. Browser preview reads this file; Android mirrors via HailRenderContract.kt after preview acceptance.",
  "payloadFields": [
    "hail_id",
    "effect_id",
    "glyph_id",
    "palette_id",
    "message",
    "duration_ms",
    "placement_id",
    "placement_mode",
    "x_percent",
    "y_percent"
  ],
  "message": {
    "maxLength": 120,
    "plainTextOnly": true
  },
  "placement": {
    "modePreset": "preset",
    "modeCustom": "custom",
    "minPercent": 5,
    "maxPercent": 95,
    "presetIds": [
      "center_soft",
      "top_right",
      "bottom_right",
      "top_left",
      "bottom_left",
      "upper_center",
      "lower_center"
    ],
    "edgeInsets": {
      "horizontalFraction": 0.065,
      "topFraction": 0.085,
      "bottomFraction": 0.105,
      "upperCenterExtraTopFraction": 0.035,
      "centerSoftVerticalFraction": 0.07
    },
    "layoutFractions": {
      "groupWidth": 0.24,
      "groupHeight": 0.26
    }
  },
  "glyphs": {
    "allowlist": ["hail-sniffer", "default"],
    "emojiFallback": {
      "hail-sniffer": "👃",
      "default": "✦"
    }
  },
  "effects": {
    "allowlist": ["transporter_beam"]
  },
  "palettes": {
